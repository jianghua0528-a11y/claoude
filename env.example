# 复制成 .env 填好; Railway 上在 Variables 里设这些
TELEGRAM_BOT_TOKEN=          # @BotFather 拿
ANTHROPIC_API_KEY=           # console.anthropic.com 拿
DATABASE_URL=                # Railway 加 Postgres 后自动注入; 本地留空则用 SQLite
REPORT_GROUP_ID=             # 报单群 chat_id
FINANCE_GROUP_ID=            # 财务流水群 chat_id
ADMIN_USER_IDS=              # 管理员 Telegram user_id, 逗号分隔
ADMIN_PASSWORD=              # 审核后台登录密码
TZ=Asia/Kuala_Lumpur
