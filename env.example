# 复制成 .env 填好; Railway 在 Variables 里设
TELEGRAM_BOT_TOKEN=          # @BotFather 拿
ANTHROPIC_API_KEY=           # console.anthropic.com 拿 (解析用)
DATABASE_URL=                # Railway 加 Postgres 后引用 ${{Postgres.DATABASE_URL}}
REPORT_GROUP_ID=             # 报单群 chat_id
FINANCE_GROUP_ID=            # 财务流水群 chat_id
ADMIN_USER_IDS=              # 管理员 Telegram user_id, 逗号分隔
ADMIN_PASSWORD=              # 审核后台登录密码
ADMIN_URL=                   # 审核后台网址(机器人回执提示用)
CLAUDE_MODEL=claude-sonnet-4-6
TZ=Asia/Kuala_Lumpur
